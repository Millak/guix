msgid ""
"\n"
"  -i, --install PACKAGE ...\n"
"                         install PACKAGEs"
msgstr ""
"\n"
"  -i, --install ΠΑΚΕΤΟ ...\n"
"                         εγκατάσταση ΠΑΚΕΤΩΝ"

