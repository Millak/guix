#, scheme-format
msgid ""
"The 'GUIX_PULL_URL' environment variable is deprecated.\n"
"Use '~/.config/guix/channels.scm' instead."
msgstr ""
"Η μεταβλητή περιβάλλοντος 'GUIX_PULL_URL' είναι παρωχημένη.\n"
