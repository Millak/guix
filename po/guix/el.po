msgstr "ο φορτωτής εκκίνησης εγκαταστάθηκε επιτυχώς στο «~a»~%"

#: guix/scripts/system.scm:892
#, scheme-format
msgid "activating system...~%"
msgstr "ενεργοποίηση συστήματος...~%"

#: guix/scripts/system.scm:903
msgid ""
"To complete the upgrade, run 'herd restart SERVICE' to stop,\n"
"upgrade, and restart each service that was not automatically restarted.\n"
msgstr ""
"Για να ολοκληρώσετε την αναβάθμιση, εκτελέστε 'herd restart ΥΠΗΡΕΣΙΑ' για να\n"
"σταματήσετε, να αναβαθμίσετε και να επανεκκινήσετε κάθε υπηρεσία που δεν\n"
"επανεκκινήθηκε αυτόματα.\n"

#: guix/scripts/system.scm:906
msgid "Run 'herd status' to view the list of services on your system.\n"
msgstr "Εκτελέστε 'herd status' για να δείτε τη λίστα των υπηρεσιών στο σύστημά σας.\n"

#: guix/scripts/system.scm:912
#, scheme-format
