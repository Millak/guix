#: guix/scripts/hash.scm:85
msgid ""
"\n"
"  -x, --exclude-vcs      exclude version control directories"
msgstr ""

#: guix/scripts/hash.scm:91
msgid ""
"\n"
"  -S, --serializer=TYPE  compute the hash on FILE according to TYPE serialization"
msgstr ""

#: guix/scripts/hash.scm:134
#, scheme-format
