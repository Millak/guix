"\n"
"  -f, --file=FILE        build the package or derivation that the code within\n"
"                         FILE evaluates to"
msgstr ""
"\n"
"  -f, --file=FILE        δόμηση του πακέτου ή της παραγωγής στην οποία αξιολογείται ο κώδικας\n"
"                         μέσα στο FILE"

#: guix/scripts/build.scm:442
msgid ""
"\n"
"  -m, --manifest=FILE    build the packages that the manifest given in FILE\n"
"                         evaluates to"
msgstr ""
"\n"
"  -m, --manifest=FILE    δόμηση των πακέτων στα οποία αξιολογείται το δηλωτικό (manifest)\n"
"                         που δίνεται στο FILE"

