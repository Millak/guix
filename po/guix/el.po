#: guix/transformations.scm:1203
#, scheme-format
msgid "Available package transformation options:~%"
msgstr "Διαθέσιμες επιλογές μετασχηματισμού πακέτων:~%"

#: guix/transformations.scm:1209
msgid ""
"\n"
"      --with-source=[PACKAGE=]SOURCE\n"
"                         use SOURCE when building the corresponding package"
msgstr ""
"\n"
"      --with-source=[ΠΑΚΕΤΟ=]ΠΗΓΗ\n"
"                         χρήση ΠΗΓΗΣ κατά τη δόμηση του αντίστοιχου πακέτου"

#: guix/transformations.scm:1212
msgid ""
"\n"
"      --with-input=PACKAGE=REPLACEMENT\n"
"                         replace dependency PACKAGE by REPLACEMENT"
msgstr ""
"\n"
"      --with-input=ΠΑΚΕΤΟ=ΑΝΤΙΚΑΤΑΣΤΑΣΗ\n"
"                         αντικατάσταση της εξάρτησης ΠΑΚΕΤΟ από την ΑΝΤΙΚΑΤΑΣΤΑΣΗ"

#: guix/transformations.scm:1215
msgid ""
"\n"
"      --with-graft=PACKAGE=REPLACEMENT\n"
"                         graft REPLACEMENT on packages that refer to PACKAGE"
msgstr ""
"\n"
"      --with-graft=ΠΑΚΕΤΟ=ΑΝΤΙΚΑΤΑΣΤΑΣΗ\n"
"                         εμβολιασμός (graft) της ΑΝΤΙΚΑΤΑΣΤΑΣΗΣ σε πακέτα που αναφέρονται στο ΠΑΚΕΤΟ"

#: guix/transformations.scm:1218
msgid ""
"\n"
"      --with-branch=PACKAGE=BRANCH\n"
"                         build PACKAGE from the latest commit of BRANCH"
msgstr ""
"\n"
"      --with-branch=ΠΑΚΕΤΟ=ΚΛΑΔΟΣ\n"
"                         δόμηση του ΠΑΚΕΤΟΥ από την τελευταία υποβολή του ΚΛΑΔΟΥ"

#: guix/transformations.scm:1221
msgid ""
"\n"
"      --with-commit=PACKAGE=COMMIT\n"
"                         build PACKAGE from COMMIT"
msgstr ""
"\n"
"      --with-commit=ΠΑΚΕΤΟ=ΥΠΟΒΟΛΗ\n"
"                         δόμηση του ΠΑΚΕΤΟΥ από την ΥΠΟΒΟΛΗ"

#: guix/transformations.scm:1224
msgid ""
"\n"
"      --with-git-url=PACKAGE=URL\n"
"                         build PACKAGE from the repository at URL"
msgstr ""
"\n"
"      --with-git-url=ΠΑΚΕΤΟ=URL\n"
"                         δόμηση του ΠΑΚΕΤΟΥ από το αποθετήριο στο URL"

#: guix/transformations.scm:1227
msgid ""
"\n"
"      --with-patch=PACKAGE=FILE\n"
"                         add FILE to the list of patches of PACKAGE"
msgstr ""
"\n"
"      --with-patch=ΠΑΚΕΤΟ=ΑΡΧΕΙΟ\n"
"                         προσθήκη ΑΡΧΕΙΟΥ στη λίστα των διορθώσεων (patches) του ΠΑΚΕΤΟΥ"

#: guix/transformations.scm:1230
msgid ""
"\n"
"      --tune[=CPU]       tune relevant packages for CPU--e.g., \"skylake\""
msgstr ""

#: guix/transformations.scm:1232
msgid ""
"\n"
"      --with-configure-flag=PACKAGE=FLAG\n"
"                         append FLAG to the configure flags of PACKAGE"
msgstr ""
"\n"
"      --with-configure-flag=ΠΑΚΕΤΟ=ΣΗΜΑΙΑ\n"
"                         προσθήκη ΣΗΜΑΙΑΣ στις σημαίες ρύθμισης (configure flags) του ΠΑΚΕΤΟΥ"

#: guix/transformations.scm:1235
msgid ""
"\n"
"      --with-latest=PACKAGE\n"
"                         use the latest upstream release of PACKAGE"
msgstr ""
"\n"
"      --with-latest=ΠΑΚΕΤΟ\n"
"                         χρήση της τελευταίας έκδοσης του δημιουργού για το ΠΑΚΕΤΟ"

#: guix/transformations.scm:1238
msgid ""
"\n"
"      --with-version=PACKAGE=VERSION\n"
"                         use the given upstream VERSION of PACKAGE"
msgstr ""
"\n"
"      --with-version=ΠΑΚΕΤΟ=ΕΚΔΟΣΗ\n"
"                         χρήση της δοθείσας έκδοσης upstream του ΠΑΚΕΤΟΥ"

#: guix/transformations.scm:1241
msgid ""
"\n"
"      --with-c-toolchain=PACKAGE=TOOLCHAIN\n"
"                         build PACKAGE and its dependents with TOOLCHAIN"
msgstr ""
"\n"
"      --with-c-toolchain=ΠΑΚΕΤΟ=ΕΡΓΑΛΕΙΟΣΕΙΡΑ\n"
"                         δόμηση του ΠΑΚΕΤΟΥ και των εξαρτώμενων από αυτό με την ΕΡΓΑΛΕΙΟΣΕΙΡΑ"

#: guix/transformations.scm:1244
msgid ""
"\n"
"      --with-debug-info=PACKAGE\n"
"                         build PACKAGE and preserve its debug info"
msgstr ""
"\n"
"      --with-debug-info=ΠΑΚΕΤΟ\n"
"                         δόμηση του ΠΑΚΕΤΟΥ και διατήρηση των πληροφοριών αποσφαλμάτωσης"

#: guix/transformations.scm:1247
msgid ""
"\n"
"      --without-tests=PACKAGE\n"
"                         build PACKAGE without running its tests"
msgstr ""
"\n"
"      --without-tests=ΠΑΚΕΤΟ\n"
"                         δόμηση του ΠΑΚΕΤΟΥ χωρίς την εκτέλεση των δοκιμών του"

#: guix/transformations.scm:1253
msgid ""
"\n"
"      --help-transform   list package transformation options not shown here"
msgstr ""
"\n"
"      --help-transform   παράθεση επιλογών μετασχηματισμού πακέτων που δεν εμφανίζονται εδώ"

