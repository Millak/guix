#, scheme-format
msgid ""
"\n"
"  -p, --profile=PROFILE  use PROFILE instead of ~/.config/guix/current"
msgstr ""
"\n"
"  -p, --profile=ПРОФИЛ   користи ПРОФИЛ уместо ~/.config/guix/current"

