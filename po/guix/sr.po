#, scheme-format
msgid "~a: invalid OpenPGP fingerprint~%"
msgstr "~a: неисправан OpenPGP отисак~%"

#: guix/scripts/git/authenticate.scm:315
#, scheme-format
msgid "~a: wrong length for OpenPGP fingerprint~%"
msgstr "~a: погрешна дужина за OpenPGP отисак~%"

