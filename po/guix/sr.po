msgid ""
"\n"
"  -q, --no-channel-files\n"
"                         inhibit loading of user and system 'channels.scm'"
msgstr ""
"\n"
"  -q, --no-channel-files\n"
"                         спречи учитавање корисничких и системских „channels.scm“"

