msgstr "погрешан број аргумената за радњу „~a“~%"

#: guix/scripts/system.scm:1512
#, scheme-format
msgid "guix system: missing command name~%"
msgstr "guix system: недостаје назив наредбе~%"

#: guix/scripts/system.scm:1514
