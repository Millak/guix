+                        // Set LCD subpixel hints explicitly.
+                        java.util.Map<java.awt.RenderingHints.Key, Object> fontHints = new java.util.HashMap<>();
+                        fontHints.put(java.awt.RenderingHints.KEY_TEXT_ANTIALIASING,
