From 760c80029e7b405e5b5d256b2a81d373329a5488 Mon Sep 17 00:00:00 2001
From: Pavel Rojtberg <rojtberg@gmail.com>
Date: Sun, 31 May 2026 13:15:43 +0200
Subject: [PATCH 1/3] Codec: STB Image - catch stbi_failure_reason = NULL

---
 PlugIns/STBICodec/src/OgreSTBICodec.cpp | 6 +++---
 1 file changed, 3 insertions(+), 3 deletions(-)

diff --git a/PlugIns/STBICodec/src/OgreSTBICodec.cpp b/PlugIns/STBICodec/src/OgreSTBICodec.cpp
index da432fdcd37..aa6f978ce14 100644
--- a/PlugIns/STBICodec/src/OgreSTBICodec.cpp
+++ b/PlugIns/STBICodec/src/OgreSTBICodec.cpp
@@ -178,9 +178,9 @@ namespace Ogre {
 
         if (!pixelData)
         {
-            OGRE_EXCEPT(Exception::ERR_INTERNAL_ERROR, 
-                "Error decoding image: " + String(stbi_failure_reason()),
-                "STBIImageCodec::decode");
+            const char* reason = stbi_failure_reason();
+            OGRE_EXCEPT(Exception::ERR_INTERNAL_ERROR,
+                        "Error decoding image: " + String(reason ? reason : "no reason"));
         }
 
         if (width <= 0 || height <= 0)

