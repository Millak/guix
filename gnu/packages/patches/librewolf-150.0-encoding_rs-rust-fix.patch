         use simd_funcs::*;
         use core::simd::u16x8;
         use core::simd::cmp::SimdPartialOrd;
+        #[rustversion::since(1.95)]
         use core::simd::Select;
 
         #[inline(always)]
         fn shift_upper(unpacked: u16x8) -> u16x8 {
